# Database Configuration
# For Railway, Render, or local development

# Database Host (e.g., localhost for local, or provided by Railway/Render)
DB_HOST=localhost

# Database Name
DB_NAME=softlink_broker

# Database User
DB_USER=root

# Database Password
DB_PASS=your_password_here

# Database Port (default: 3306 for MySQL)
DB_PORT=3306

# Application Environment (development, production)
APP_ENV=development

# Session Secret (for security)
SESSION_SECRET=your_session_secret_here
