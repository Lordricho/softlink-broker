# Softlink Broker Configuration
# For PostgreSQL (Render, Railway, or local development)

# Database Host (for Render/Railway, they provide this)
DB_HOST=localhost

# Database Name
DB_NAME=softlink_broker

# Database User (PostgreSQL default is 'postgres')
DB_USER=postgres

# Database Password
DB_PASS=your_password_here

# Database Port (PostgreSQL default: 5432)
DB_PORT=5432

# Application Environment (development, production)
APP_ENV=development

# Session Secret (for security)
SESSION_SECRET=your_session_secret_here

# --- Render Environment Variables ---
# When deploying on Render, copy these from your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Extract and set individually:
# DB_HOST=host
# DB_NAME=dbname
# DB_USER=user
# DB_PASS=password
# DB_PORT=5432
